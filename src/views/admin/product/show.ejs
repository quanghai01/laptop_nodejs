<%- include('../layout/head.ejs') %>

    <body>
        <%- include('../layout/sidebar.ejs') %>
            <div id="content">
                <%- include('../layout/navbar.ejs') %>
                    <div class="main-container">
                        <div class="d-flex justify-content-between align-items-center mb-4 fade-in">
                            <div>
                                <h2 class="fw-bold mb-1">Products</h2>
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb mb-0">
                                        <li class="breadcrumb-item"><a href="/admin/dashboard/show"
                                                class="text-decoration-none text-secondary">Dashboard</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">Products</li>
                                    </ol>
                                </nav>
                            </div>
                            <a href="/admin/product/create" class="btn btn-primary d-flex align-items-center gap-2">
                                <i class="fas fa-plus"></i>
                                <span>New Product</span>
                            </a>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-12">
                                <div class="card shadow-sm border-0">
                                    <div class="card-body p-0">
                                        <table class="table table-premium mb-0 text-center">
                                            <thead>
                                                <tr>
                                                    <th>ID</th>
                                                    <th>Product</th>
                                                    <th>Category</th>
                                                    <th>Price</th>
                                                    <th>Quantity</th>
                                                    <th>Sold</th>
                                                    <th>Image</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% products.forEach(product=> { %>
                                                    <tr>
                                                        <td class="fw-medium text-secondary">
                                                            <%= product.id %>
                                                        </td>
                                                        <td>
                                                            <div class="fw-bold text-dark">
                                                                <%= product.name %>
                                                            </div>
                                                            <div class="small text-muted">@product-1
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="small"><i
                                                                    class="fa-solid fa-tag me-1 text-muted"></i>
                                                                <%= product.category.name %>
                                                            </div>
                                                            <div class="small text-muted">
                                                                <%= product.description %>
                                                            </div>
                                                        </td>

                                                        <td>$<%= product.price %>
                                                        </td>

                                                        <td>
                                                            <%= product.quantity %>
                                                        </td>

                                                        <td>
                                                            <%= product.sold %>
                                                        </td>

                                                        <td>
                                                            <img src="/images/products/<%= product.image %>"
                                                                alt="Product Image" class="img-fluid"
                                                                style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;">
                                                        </td>

                                                        <td class="text-end">
                                                            <div class="d-flex gap-2 justify-content-center">
                                                                <a class="btn btn-action btn-soft-primary" href="/"
                                                                    title="Edit">
                                                                    <i class="fa-solid fa-pen-to-square"></i>
                                                                </a>
                                                                <form action="/" method="POST" class="d-inline">
                                                                    <button class="btn btn-action btn-soft-danger"
                                                                        type="submit" title="Delete"
                                                                        onclick="return confirm('Are you sure?')">
                                                                        <i class="fa-solid fa-trash"></i>
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
            </div>
            <%- include('../layout/scripts.ejs') %>
    </body>

    </html>
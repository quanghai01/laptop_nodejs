<%- include('layout/head.ejs') %>

    <body>
        <%- include('layout/header.ejs') %>

            <!-- Hero Section -->
            <header class="hero-section text-white text-center py-5">
                <div class="hero-overlay"
                    style="background: url('/images/hero_luxury_banner_1775450361666.png') center/cover; opacity: 0.6; z-index: -1;">
                </div>
                <div class="container py-5 animate__animated animate__fadeIn">
                    <h1 class="display-3 fw-bold mb-4 tracking-tighter" style="font-family: 'Playfair Display', serif;">
                        The Art of Premium Living</h1>
                    <p class="lead mb-4 mx-auto"
                        style="max-width: 600px; color: #f8fafc; font-weight: 300; letter-spacing: 1px;">Discover our
                        curated collection of high-end accessories and designer essentials designed for the modern
                        connoisseur.</p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="#featured" class="btn btn-premium px-5 py-3 fs-5">SHOP COLLECTION</a>
                        <a href="#" class="btn btn-outline-light rounded-pill px-5 py-3 fs-5"
                            style="border-width: 2px;">VIRTUAL TOUR</a>
                    </div>
                </div>
            </header>

            <!-- Featured Categories -->
            <section class="container my-5 py-5">
                <div class="row text-center mb-5 fade-in-up">
                    <div class="col-12">
                        <h6 class="text-primary fw-bold tracking-widest text-uppercase mb-2">Exclusive</h6>
                        <h2 class="display-5 mb-3">Shop by Category</h2>
                        <div class="mx-auto" style="width: 60px; height: 3px; background-color: var(--primary-color);">
                        </div>
                    </div>
                </div>
                <div class="row g-4 mb-5">
                    <% if (categories && categories.length> 0) { %>
                        <% categories.forEach((category, index)=> { %>
                            <div class="col-md-3">
                                <div class="product-card position-relative overflow-hidden fade-in-up" <%-
                                    `style="animation-delay: ${(index + 1) * 0.1}s;" ` %>>
                                    <div class="product-image-container">
                                        <img src="<%= category.image ? '/images/categories/' + category.image : 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=2000' %>"
                                            class="product-image" alt="<%= category.name %>">
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 w-100 p-4"
                                        style="background: linear-gradient(0deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);">
                                        <h4 class="text-white mb-1">
                                            <%= category.name %>
                                        </h4>
                                        <a href="/category/<%= category.id %>"
                                            class="text-white-50 text-decoration-none small">Explore All <i
                                                class="fas fa-arrow-right ms-1"></i></a>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="col-12 text-center">
                                        <p class="text-muted">No categories available.</p>
                                    </div>
                                    <% } %>
                </div>
            </section>

            <!-- All Products -->
            <section id="featured" class="container my-5 py-5">
                <div class="d-flex justify-content-between align-items-end mb-5 fade-in-up">
                    <div>
                        <h6 class="text-primary fw-bold tracking-widest text-uppercase mb-2">Collection</h6>
                        <h2 class="display-5 mb-0">All Products</h2>
                    </div>
                    <a href="/products" class="btn btn-outline-primary rounded-pill px-4">VIEW ALL <i
                            class="fas fa-arrow-right ms-2"></i></a>
                </div>
                <div class="row g-4">
                    <% if (products && products.length> 0) { %>
                        <% products.forEach((product, index)=> { %>
                            <!-- Product Item -->
                            <div class="col-6 col-lg-3">
                                <a href="/product/<%= product.id %>" class="text-decoration-none">
                                    <div class="product-card fade-in-up" <%-
                                        `style="animation-delay: ${(index % 4 + 1) * 0.1}s;" ` %>>
                                        <div class="product-image-container">
                                            <img src="<%= product.image ? '/images/products/' + product.image : 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=2000' %>"
                                                class="product-image" alt="<%= product.name %>">
                                            <% if (product.sold> 50) { %>
                                                <div class="position-absolute top-0 end-0 m-3">
                                                    <span
                                                        class="badge bg-white text-dark rounded-pill px-3 py-2 shadow-sm fw-bold">BEST
                                                        SELLER</span>
                                                </div>
                                                <% } %>
                                        </div>
                                        <div class="p-4">
                                            <h5 class="mb-1 text-heading text-truncate">
                                                <%= product.name %>
                                            </h5>
                                            <p class="text-muted small mb-3">
                                                <%= product.category ? product.category.name : 'Uncategorized' %>
                                            </p>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="fs-4 fw-bold text-primary">$<%=
                                                        product.price.toLocaleString() %></span>
                                                <button class="btn btn-sm btn-premium rounded-circle p-2"
                                                    style="width: 40px; height: 40px;"><i
                                                        class="fas fa-plus"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="col-12 text-center">
                                        <p class="text-muted">No products available at the moment.</p>
                                    </div>
                                    <% } %>
                </div>
            </section>

            <!-- Why Choose Us -->
            <section class="bg-white py-5 mt-5">
                <div class="container py-5">
                    <div class="row g-4">
                        <div class="col-md-4 text-center px-4 animate-on-scroll">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle mx-auto d-flex align-items-center justify-content-center mb-4"
                                style="width: 80px; height: 80px;">
                                <i class="fas fa-shipping-fast fs-3"></i>
                            </div>
                            <h4 class="mb-3">Express Shipping</h4>
                            <p class="text-secondary small">Global priority delivery within 3-5 business days. Seamless
                                tracking included.</p>
                        </div>
                        <div class="col-md-4 text-center px-4 animate-on-scroll" style="transition-delay: 0.1s;">
                            <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle mx-auto d-flex align-items-center justify-content-center mb-4"
                                style="width: 80px; height: 80px;">
                                <i class="fas fa-shield-alt fs-3"></i>
                            </div>
                            <h4 class="mb-3">Secure Payments</h4>
                            <p class="text-secondary small">Your data is encrypted with military-grade 256-bit SSL
                                protocols.</p>
                        </div>
                        <div class="col-md-4 text-center px-4 animate-on-scroll" style="transition-delay: 0.2s;">
                            <div class="bg-accent bg-opacity-10 text-accent rounded-circle mx-auto d-flex align-items-center justify-content-center mb-4"
                                style="width: 80px; height: 80px; color: var(--accent-color);">
                                <i class="fas fa-undo fs-3"></i>
                            </div>
                            <h4 class="mb-3">30 Days Return</h4>
                            <p class="text-secondary small">Not satisfied? We offer a no-questions-asked 30-day return
                                policy for your peace of mind.</p>
                        </div>
                    </div>
                </div>
            </section>

            <%- include('layout/footer.ejs') %>
                <%- include('layout/scripts.ejs') %>
    </body>

    </html>